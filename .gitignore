# Data — never commit (use kaggle CLI to re-download)
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/*/.gitkeep

# Outputs — large, regenerable
outputs/oof/*
outputs/preds/*
outputs/models/*
outputs/logs/*
!outputs/*/.gitkeep

# MLflow local store
mlruns/
mlartifacts/

# Python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/
.venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local env
.env
.env.local

# Kaggle download artifacts
*.zip

# NN model checkpoints — regenerable via training
*.pt
agents/proxy/*.zip

# Tournament logs (root-level) — regenerable
/tournament_*.csv

# Submission archive: keep CSV, ignore raw kaggle stdout
submissions/*.txt

# Notebook output (nbstripout handles this on commit, but keep gitignore as belt+suspenders)
*-checkpoint.ipynb

# Replay JSON downloads — large, regenerable via `kaggle competitions replay`
data/replays/*
!data/replays/.gitkeep

# ELO ledger — local state, regenerable from tournament logs
elo.json
/tournament_log.csv
!experiments/**/tournament_log.csv
